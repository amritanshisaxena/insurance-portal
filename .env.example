# Server
PORT=3001
NODE_ENV=development

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secret (change in production!)
JWT_SECRET=dev-secret-change-me

# Browser Pool
BROWSER_POOL_SIZE=2

# Optional: Residential Proxy (pick one provider)
# BrightData:
# PROXY_SERVER=http://brd.superproxy.io:22225
# PROXY_USERNAME=brd-customer-<CUSTOMER_ID>-zone-<ZONE>
# PROXY_PASSWORD=<PASSWORD>
#
# Decodo (Smartproxy):
# PROXY_SERVER=http://gate.decodo.com:7000
# PROXY_USERNAME=user-<USERNAME>
# PROXY_PASSWORD=<PASSWORD>
